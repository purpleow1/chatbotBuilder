NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase values are wired in Steps 2-3.
NEXT_PUBLIC_SUPABASE_URL=
# Prefer a publishable key for Auth. A legacy anon key is also supported.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Only use the anon key for Supabase Auth/Realtime in browser code. CRUD uses API routes.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Gemini API and billing values are used in later steps.
GEMINI_API_KEY=
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
